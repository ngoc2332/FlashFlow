POSTGRES_URL=postgres://flashflow:flashflow@localhost:5432/flashflow
KAFKA_BROKERS=localhost:9092
ORDER_API_PORT=3000
ORDER_QUERY_API_PORT=3001
OUTBOX_CLIENT_ID=flashflow-outbox-publisher
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
PAYMENT_CLIENT_ID=flashflow-payment-worker
PAYMENT_CONSUMER_GROUP=payment-workers
PAYMENT_EVENTS_TOPIC=payment.events
PAYMENT_APPROVAL_LIMIT=1000
PAYMENT_FAIL_USER_PREFIX=fail-payment
INVENTORY_CLIENT_ID=flashflow-inventory-worker
INVENTORY_CONSUMER_GROUP=inventory-workers
INVENTORY_EVENTS_TOPIC=inventory.events
INVENTORY_REJECT_USER_PREFIX=reject-inventory
INVENTORY_FAIL_USER_PREFIX=fail-inventory
INVENTORY_RESERVE_LIMIT=800
STATUS_UPDATER_CLIENT_ID=flashflow-order-status-updater
STATUS_UPDATER_CONSUMER_GROUP=order-status-updaters
ORDER_STATUS_TOPIC=order.status
RETRY_TOPIC_5S=order.retry.5s
RETRY_TOPIC_1M=order.retry.1m
ORDER_DLQ_TOPIC=order.dlq
SCHEMA_REGISTRY_URL=http://localhost:8081
ORDER_CREATED_SUBJECT=order.created-value
